description="DisplayLink userspace driver"
command="/usr/libexec/displaylink/DisplayLinkManager"
directory="/usr/libexec/displaylink"
supervisor="supervise-daemon"
respawn_delay=5

depend() {
	need localmount
	after display-manager
}

start_pre() {
	modprobe evdi
}
