-    BUILT_MODULE_LOCATION[6]="drivers/media/i2c"
-    DEST_MODULE_LOCATION[6]="/updates"
+    BUILT_MODULE_NAME[7]="ov2740"
+    BUILT_MODULE_LOCATION[7]="drivers/media/i2c"
+    DEST_MODULE_LOCATION[7]="/updates"
@@ -84,3 +87,3 @@
